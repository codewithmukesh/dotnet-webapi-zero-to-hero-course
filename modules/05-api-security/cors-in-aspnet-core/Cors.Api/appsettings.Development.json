{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Cors": "Debug"
    }
  },
  "Cors": {
    "AcmeFrontend": {
      "Origins": [
        "https://localhost:5173",
        "https://localhost:4200",
        "http://localhost:3000"
      ],
      "Methods": [ "GET", "POST", "PUT", "DELETE", "PATCH" ],
      "Headers": [ "Authorization", "Content-Type", "X-Correlation-Id" ],
      "ExposedHeaders": [ "X-Total-Count", "X-Correlation-Id", "Location" ],
      "AllowCredentials": true,
      "PreflightMaxAgeSeconds": 60
    },
    "PublicWebhooks": {
      "Origins": [ "https://stripe.com" ],
      "Methods": [ "POST" ],
      "Headers": [ "Content-Type", "Stripe-Signature" ],
      "AllowCredentials": false,
      "PreflightMaxAgeSeconds": 60
    }
  }
}
