{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Cors": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AcmeFrontend": {
      "Origins": [
        "https://app.acme.com",
        "https://admin.acme.com"
      ],
      "Methods": [ "GET", "POST", "PUT", "DELETE", "PATCH" ],
      "Headers": [ "Authorization", "Content-Type", "X-Correlation-Id" ],
      "ExposedHeaders": [ "X-Total-Count", "X-Correlation-Id", "Location" ],
      "AllowCredentials": true,
      "PreflightMaxAgeSeconds": 600
    },
    "PublicWebhooks": {
      "Origins": [ "https://stripe.com", "https://hooks.stripe.com" ],
      "Methods": [ "POST" ],
      "Headers": [ "Content-Type", "Stripe-Signature" ],
      "AllowCredentials": false,
      "PreflightMaxAgeSeconds": 300
    }
  }
}
